---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  alt: string;
  label: string;
  speed: number;
  depth?: number;
  src?: ImageMetadata;
  inset?: string;
  priority?: boolean;
  class?: string;
}

const {
  alt,
  label,
  speed,
  depth = 1,
  src,
  inset = "0%",
  priority = false,
  class: className = ""
} = Astro.props;

const layerStyle = `--layer-inset:${inset}`;
---

<div
  class={`parallax-layer ${className}`}
  data-speed={speed}
  data-depth={depth}
  data-active="false"
>
  {
    src ? (
      <div class="parallax-layer__frame" style={layerStyle}>
        <Image
          src={src}
          alt={alt}
          loading={priority ? "eager" : "lazy"}
          decoding="async"
          class="parallax-layer__image"
        />
      </div>
    ) : (
      <div class="parallax-layer__frame" style={layerStyle}>
        <div class="parallax-layer__placeholder">
          <span class="parallax-layer__label">{label}</span>
        </div>
      </div>
    )
  }
</div>
