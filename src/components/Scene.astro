---
interface Props {
  id: string;
  eyebrow: string;
  title: string;
  description: string;
  align?: "start" | "center" | "end";
  pin?: boolean;
}

const { id, eyebrow, title, description, align = "start", pin = false } = Astro.props;

const alignClass = {
  start: "items-start text-left",
  center: "items-center text-center",
  end: "items-end text-right"
}[align];
---

<section
  id={id}
  class="scene"
  data-scene
  data-pin={pin ? "true" : "false"}
  aria-labelledby={`${id}-title`}
>
  <div class="scene__shell" data-scene-shell>
    <div class="scene__layers" aria-hidden="true">
      <slot name="layers" />
    </div>

    <div class={`scene__content ${alignClass}`} data-scene-copy>
      <p class="scene__eyebrow">{eyebrow}</p>
      <h2 id={`${id}-title`} class="scene__title">{title}</h2>
      <p class="scene__description">{description}</p>
      <div class="scene__body">
        <slot />
      </div>
    </div>
  </div>
</section>
